{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/schemas/qmd-recall.schema.json",
  "title": "QMD Recall Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "default": ""
    },
    "collections": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "minScore": {
      "type": "number",
      "default": 0.0
    },
    "topN": {
      "type": "integer",
      "default": 3
    },
    "queryTimeout": {
      "type": "integer",
      "default": 5
    },
    "lexicalPatterns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "skipPaths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "collectionPaths": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "allowRoots": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "prefixStyle": {
      "type": "string",
      "enum": [
        "full",
        "tag"
      ],
      "default": "full"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "sessionStart",
          "userPromptSubmit",
          "postToolUse"
        ]
      },
      "default": [
        "sessionStart",
        "userPromptSubmit",
        "postToolUse"
      ]
    }
  }
}
