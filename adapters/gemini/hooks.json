{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 @@REPO_ROOT@@/adapters/gemini/wrapper.py update"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 @@REPO_ROOT@@/adapters/gemini/wrapper.py recall"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "python3 @@REPO_ROOT@@/adapters/gemini/wrapper.py posttool"
          }
        ]
      }
    ]
  }
}
