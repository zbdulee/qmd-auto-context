{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 @@REPO_ROOT@@/adapters/claude/wrapper.py update"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 @@REPO_ROOT@@/adapters/claude/wrapper.py recall"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 @@REPO_ROOT@@/adapters/claude/wrapper.py posttool"
          }
        ]
      }
    ]
  }
}
