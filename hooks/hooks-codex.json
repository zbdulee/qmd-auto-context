{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/run-hook\" update codex" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/run-hook\" recall codex" } ] }
    ],
    "PreToolUse": [
      { "matcher": "apply_patch|Edit|Write",
        "hooks": [
          { "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/run-hook\" gate codex" }
        ] }
    ],
    "PostToolUse": [
      { "matcher": "apply_patch|Edit|Write",
        "hooks": [
          { "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/run-hook\" posttool codex" },
          { "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/run-hook\" index codex" },
          { "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/run-hook\" compile codex" }
        ] }
    ]
  }
}
