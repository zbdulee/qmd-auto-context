#!/usr/bin/env bash
# qmd auto-context 공통 hook 디스패처.
# usage: run-hook <action> <engine> [--sandbox]
#   action: recall | update | posttool | index | gate
#   engine: claude | codex | gemini
# 플러그인 루트는 CLAUDE_PLUGIN_ROOT/PLUGIN_ROOT(있으면) 또는 스크립트 위치(dirname)로 결정.
set -u

ACTION="${1:-}"
ENGINE="${2:-claude}"

# 인자 없이 호출 시 usage 안내
if [ -z "$ACTION" ]; then
  echo "usage: run-hook <recall|update|posttool|index|gate> <claude|codex|gemini>" >&2
  exit 1
fi

# 1) 플러그인 루트 결정 — 변수 우선, 없으면 스크립트 위치 기준(hooks/run-hook → 루트)
ROOT="${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-}}"
if [ -z "$ROOT" ]; then
  ROOT="$(cd "$(dirname "$0")/.." && pwd)" || { echo "run-hook: cannot resolve plugin root" >&2; exit 1; }
fi

# 2) sandbox/headless → 무출력 종료 (정상 동작)
case " $* " in *" --sandbox "*) exit 0 ;; esac
[ -n "${QMD_SANDBOX:-}" ] && exit 0
case "$ENGINE" in
  claude) { [ "${CLAUDE_HEADLESS:-}" = "1" ] || [ -n "${CLAUDE_SANDBOX:-}" ]; } && exit 0 ;;
  codex)  [ -n "${CODEX_SANDBOX:-}" ] && exit 0 ;;
  gemini) [ -n "${GEMINI_SANDBOX:-}" ] && exit 0 ;;
esac

# 3) engine 라벨 + 로그 경로 기본값
# 기본 로그는 유저 격리 경로($HOME/.cache/qmd, backend_manager의 MANAGER_LOG/DAEMON_LOG와 동일 베이스).
# 예측가능한 /tmp 경로는 멀티유저 symlink 선점 클래스 문제라 기본값에서 제거한다.
# QMD_RECALL_LOG override는 반드시 유지(테스트가 주입한다).
export QMD_ENGINE="$ENGINE"
_QMD_HOOK_LOG_DIR="${QMD_CACHE_DIR:-$HOME/.cache/qmd}"
mkdir -p "$_QMD_HOOK_LOG_DIR" 2>/dev/null || true
: "${QMD_RECALL_LOG:=$_QMD_HOOK_LOG_DIR/qmd-${ENGINE}-hook.log}"
export QMD_RECALL_LOG

# 4) action → backend lifecycle + core 위임
MANAGER="${QMD_BACKEND_MANAGER:-$ROOT/core/backend_manager.sh}"

case "$ACTION" in
  recall)
    if [ -z "${QMD_QUERY_FIXTURE:-}" ]; then
      bash "$MANAGER" ensure >/dev/null 2>&1 &
    fi
    exec python3 "${QMD_CORE_RECALL_SCRIPT:-$ROOT/core/recall.py}"
    ;;
  update)
    bash "$MANAGER" ensure --wait >/dev/null 2>&1 || true
    bash "$MANAGER" warm >/dev/null 2>&1 || true
    bash "$MANAGER" rotate >/dev/null 2>&1 || true
    QMD_BACKEND_MANAGER="$MANAGER" exec bash "${QMD_CORE_UPDATE_SCRIPT:-$ROOT/core/update.sh}"
    ;;
  posttool)
    bash "$MANAGER" ensure --wait >/dev/null 2>&1 || true
    exec python3 "${QMD_CORE_POSTTOOL_SCRIPT:-$ROOT/core/posttool.py}"
    ;;
  index)
    tmp="$(mktemp 2>/dev/null || true)"
    if [ -z "$tmp" ]; then
      cat >/dev/null 2>&1 || true
      exit 0
    fi
    if ! cat >"$tmp" 2>/dev/null; then
      rm -f "$tmp"
      exit 0
    fi
    python3 "${QMD_CORE_INDEX_SCRIPT:-$ROOT/core/index_enqueue.py}" <"$tmp" >/dev/null 2>&1 || true
    rm -f "$tmp"
    bash "$MANAGER" kick-index >/dev/null 2>&1 || true
    exit 0
    ;;
  gate)     exec python3 "$ROOT/core/preflight_gate.py" ;;
  *) echo "run-hook: unknown action '$ACTION'" >&2; exit 1 ;;
esac
